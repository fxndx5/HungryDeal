{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Arrancar Backend",
            "type": "shell",
            "command": "python -m uvicorn app.main:app --reload --port 8000",
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}/backend"
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "INFO.*Uvicorn running",
                    "endsPattern": "INFO.*Application startup complete"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "hungrydeal"
            }
        },
        {
            "label": "Ejecutar Tests Auth",
            "type": "shell",
            "command": "python test_auth.py",
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}/backend"
                }
            },
            "dependsOn": "Arrancar Backend",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "hungrydeal"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Instalar Dependencias",
            "type": "shell",
            "command": "pip install -r requirements.txt",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
