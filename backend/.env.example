# Copia este archivo como .env y rellena los valores reales

# Base de datos (Supabase transaction pooler, puerto 6543)
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[PASSWORD]@aws-1-eu-west-3.pooler.supabase.com:6543/postgres

# JWT — genera una clave segura con: openssl rand -hex 32
SECRET_KEY=cambia_esto_por_una_clave_segura_de_64_caracteres

# Entorno
APP_ENV=development
DEBUG=true
ACCESS_TOKEN_EXPIRE_DAYS=30

# CORS — origenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:3000

# Supabase (opcional, para uso del cliente JS)
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_ANON_KEY=
